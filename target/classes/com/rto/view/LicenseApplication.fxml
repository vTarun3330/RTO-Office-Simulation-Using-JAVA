<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15" alignment="TOP_CENTER" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rto.controller.LicenseController">
    <VBox spacing="5" alignment="CENTER_LEFT" maxWidth="500" styleClass="card">
        <Label text="Apply for Driving License" styleClass="header-label"/>
        <Label text="Fill out your details" styleClass="sub-header"/>
        
        <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
            <Label text="Application Details" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            
            <HBox spacing="10">
                 <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="License Type"/>
                    <ChoiceBox fx:id="licenseTypeBox" maxWidth="Infinity"/>
                 </VBox>
                 <VBox HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Blood Group"/>
                    <ChoiceBox fx:id="bloodGroupBox" maxWidth="Infinity"/>
                 </VBox>
            </HBox>
            
            <TextField fx:id="nameField" promptText="Full Name"/>
            <TextField fx:id="emailField" promptText="Email Address"/>
            <TextArea fx:id="addressField" promptText="Permanent Address" prefRowCount="3"/>
        </VBox>
        
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
            <Button text="Submit Application" onAction="#handleSubmit" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>
        
        <Label fx:id="statusLabel" wrapText="true" style="-fx-padding: 10 0 0 0;"/>
    </VBox>
</VBox>
