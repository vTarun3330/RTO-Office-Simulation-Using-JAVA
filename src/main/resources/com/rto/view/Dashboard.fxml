<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rto.controller.DashboardController">
   <top>
      <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #2C3E50; -fx-padding: 15;">
         <Label text="RTO System" textFill="WHITE" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
         <HBox HBox.hgrow="ALWAYS" />
         <Label fx:id="welcomeLabel" text="Welcome, User" textFill="WHITE" style="-fx-font-size: 14px;"/>
         <Button text="Logout" onAction="#handleLogout" styleClass="button-secondary"/>
      </HBox>
   </top>
   <center>
      <TabPane fx:id="mainTabPane" style="-fx-background-color: transparent;">
         <tabs>
            <Tab fx:id="vehicleTab" text="Vehicle Registration" closable="false">
               <content>
                   <VBox spacing="20" style="-fx-padding: 20;">
                       <!-- Registration content will be loaded here -->
                   </VBox>
               </content>
            </Tab>
            <Tab fx:id="licenseTab" text="License Application" closable="false">
                 <content>
                     <VBox alignment="CENTER" style="-fx-padding: 20;">
                        <Label text="License Services Coming Soon" styleClass="sub-header"/>
                     </VBox>
                 </content>
             </Tab>
             <Tab fx:id="transferTab" text="Transfer Ownership" closable="false">
                 <content>
                     <VBox alignment="CENTER" style="-fx-padding: 20;">
                        <Label text="Transfer Form"/>
                     </VBox>
                 </content>
             </Tab>
             <Tab fx:id="cbtTab" text="Take LL Test" closable="false">
                 <content>
                     <VBox alignment="CENTER" style="-fx-padding: 20;">
                        <Label text="CBT Test"/>
                     </VBox>
                 </content>
             </Tab>
         </tabs>
      </TabPane>
   </center>
</BorderPane>
