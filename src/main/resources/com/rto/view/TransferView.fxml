<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rto.controller.TransferController">
  <VBox spacing="20" style="-fx-padding: 30;">

    <Label text="Vehicle Ownership Transfer" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
    
    <TabPane fx:id="transferTabPane" tabClosingPolicy="UNAVAILABLE">
        
        <!-- SELLER TAB -->
        <Tab fx:id="sellerTab" text="I'm Selling My Vehicle">
            <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
                
                <Label text="Step 1: Select Your Vehicle" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <Label text="Only admin-approved registered vehicles are shown below." style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
                <ChoiceBox fx:id="vehicleChoiceBox" prefWidth="400"/>
                
                <Button text="Check Transfer Eligibility" onAction="#handleCheckEligibility" 
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10;"/>
                
                <Label fx:id="validationResultLabel" wrapText="true" prefWidth="500" style="-fx-padding: 10; -fx-background-color: #ecf0f1;"/>
                
                <Separator/>
                
                <Label text="Step 2: Enter Buyer Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <Label text="Enter the username of the buyer who will receive the vehicle." style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Buyer Username:" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                    <TextField fx:id="buyerUsernameField" promptText="Enter buyer's username" prefWidth="200"/>
                </HBox>
                
                <Button fx:id="initiateTransferBtn" text="Initiate Transfer" onAction="#handleInitiateTransfer"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10; -fx-font-size: 14px;"
                        disable="true"/>
                
                <Label fx:id="tokenLabel" wrapText="true" style="-fx-padding: 15; -fx-background-color: #d5f4e6; -fx-border-color: #27ae60; -fx-border-width: 2;"/>
                
                <Label text="Note: Share the token with the buyer. They will use it in the 'I'm Buying a Vehicle' tab to confirm the transfer." 
                       wrapText="true" style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
            </VBox>
        </Tab>
        
        <!-- BUYER TAB -->
        <Tab fx:id="buyerTab" text="I'm Buying a Vehicle">
            <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
                
                <Label text="Complete Transfer Using Token" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                
                <Label text="Enter the 6-digit token provided by the seller:" wrapText="true" style="-fx-text-fill: #2C3E50;"/>
                
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Transfer Token:" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                    <TextField fx:id="tokenInputField" promptText="Enter token" prefWidth="150"/>
                </HBox>
                
                <Button fx:id="confirmTransferBtn" text="Confirm Transfer &amp; Pay Fee (₹500)" onAction="#handleConfirmTransfer"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-padding: 10; -fx-font-size: 14px;"/>
                
                <Label fx:id="buyerStatusLabel" wrapText="true" prefWidth="500" style="-fx-padding: 10;"/>
                
                <Separator/>
                
                <Label text="What happens next?" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <Label text="1. Transfer fee (₹500) will be collected" style="-fx-text-fill: #555;"/>
                <Label text="2. Request will be sent to RTO for approval" style="-fx-text-fill: #555;"/>
                <Label text="3. Once approved, vehicle ownership will transfer to you" style="-fx-text-fill: #555;"/>
                
            </VBox>
        </Tab>
        
    </TabPane>
    
  </VBox>
</ScrollPane>
